              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if(d.id){ pm.collectionVariables.set('jobId', d.id); console.log('jobId saved: '+d.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
