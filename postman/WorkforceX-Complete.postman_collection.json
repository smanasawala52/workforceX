{
  "info": {
    "name": "WorkforceX - Complete API",
    "description": "WorkforceX backend API collection.\n\nFLOW:\n1. Run 'Register + Login (Worker)' \u2192 {{workerToken}} auto-saved\n2. Run 'Register + Login (Employer)' \u2192 {{employerToken}} auto-saved\n3. Use each folder with the correct token variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "workerToken",
      "value": ""
    },
    {
      "key": "employerToken",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Worker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"role\": \"WORKER\",\n  \"countryCode\": \"+91\"\n}"
            }
          }
        },
        {
          "name": "Register Employer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9123456780\",\n  \"role\": \"EMPLOYER\",\n  \"countryCode\": \"+91\"\n}"
            }
          }
        },
        {
          "name": "Login Worker \u2192 saves {{workerToken}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if(d.token){ pm.collectionVariables.set('workerToken', d.token); console.log('workerToken saved'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"password\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Login Employer \u2192 saves {{employerToken}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json();",
                  "if(d.token){ pm.collectionVariables.set('employerToken', d.token); console.log('employerToken saved'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9123456780\",\n  \"password\": \"9123456780\"\n}"
            }
          }
        },
        {
          "name": "Register - Duplicate (should 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"role\": \"WORKER\",\n  \"countryCode\": \"+91\"\n}"
            }
          }
        },
        {
          "name": "Register - Invalid Mobile (should 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"12345\",\n  \"role\": \"WORKER\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Worker Profile (use workerToken)",
      "item": [
        {
          "name": "Save / Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{workerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/worker/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "worker",
                "profile"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ramesh Kumar\",\n  \"gender\": \"Male\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"skills\": \"security,patrolling,cctv\",\n  \"experience\": 5,\n  \"preferredSalary\": 16000\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{workerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/worker/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "worker",
                "profile"
              ]
            }
          }
        },
        {
          "name": "Upload Resume PDF",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{workerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/worker/resume",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "worker",
                "resume"
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "Select a PDF resume from your machine"
                }
              ]
            }
          }
        },
        {
          "name": "Get Profile - No Token (should 401/403)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/worker/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "worker",
                "profile"
              ]
            }
          }
        }
      ]
    },
