{
  "info": {
    "name": "WorkforceX - Spiral 1",
    "description": "Manual test collection for WorkforceX backend. Update {{baseUrl}} if needed (defaults to local dev server).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Worker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"role\": \"WORKER\"\n}"
            }
          }
        },
        {
          "name": "Register Employer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9123456780\",\n  \"role\": \"EMPLOYER\"\n}"
            }
          }
        },
        {
          "name": "Register - Duplicate Mobile (should fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"role\": \"WORKER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('token', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"password\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Register - Invalid Mobile (should fail validation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"12345\",\n  \"role\": \"WORKER\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Worker Profile",
      "item": [
        {
          "name": "Save/Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/worker/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "worker",
                "profile"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ramesh Kumar\",\n  \"gender\": \"Male\",\n  \"dateOfBirth\": \"1995-04-12\",\n  \"email\": \"ramesh@example.com\",\n  \"address\": \"123 MG Road\",\n  \"city\": \"Ahmedabad\",\n  \"state\": \"Gujarat\",\n  \"skills\": \"driving,security\",\n  \"experience\": 5,\n  \"preferredSalary\": 18000\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/worker/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "worker",
                "profile"
              ]
            }
          }
        },
        {
          "name": "Get My Profile - No Token (should fail)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/worker/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "worker",
                "profile"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Security Guard\",\n  \"skillsRequired\": \"security,patrolling\",\n  \"experienceRequired\": 2,\n  \"location\": \"Ahmedabad\",\n  \"salary\": 15000,\n  \"description\": \"Night shift security guard\"\n}"
            }
          }
        },
        {
          "name": "Get My Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs"
              ]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{jobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs",
                "{{jobId}}"
              ]
            }
          }
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{jobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs",
                "{{jobId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Security Guard\",\n  \"skillsRequired\": \"security,patrolling\",\n  \"experienceRequired\": 5,\n  \"location\": \"Ahmedabad\",\n  \"salary\": 20000,\n  \"description\": \"Updated\"\n}"
            }
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{jobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs",
                "{{jobId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Matching Engine",
      "item": [
        {
          "name": "Get Matched Workers for Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/matching/{{jobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "matching",
                "{{jobId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}