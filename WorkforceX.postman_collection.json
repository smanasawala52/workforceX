{
	"info": {
		"_postman_id": "a8f5f2c1-c5a8-43c0-9b4e-0b8b0b8b0b8b",
		"name": "WorkforceX",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"mobileNumber\": \"1234567890\",\n    \"password\": \"password\",\n    \"role\": \"EMPLOYER\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "auth", "register" ]
						}
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"mobileNumber\": \"1234567890\",\n    \"password\": \"password\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "auth", "login" ]
						}
					}
				}
			]
		},
		{
			"name": "Applications",
			"item": [
				{
					"name": "Update Application Status",
					"request": {
						"method": "PUT",
						"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
						"url": {
							"raw": "{{baseUrl}}/api/applications/{{applicationId}}/status?status=HIRED",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "applications", "{{applicationId}}", "status" ],
							"query": [ { "key": "status", "value": "HIRED" } ]
						}
					}
				},
                {
                    "name": "Offer Job to Worker",
                    "request": {
                        "method": "POST",
                        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
                        "url": {
                            "raw": "{{baseUrl}}/api/applications/offer?jobId={{jobId}}&workerId={{workerId}}",
                            "host": [ "{{baseUrl}}" ],
                            "path": [ "api", "applications", "offer" ],
                            "query": [
                                { "key": "jobId", "value": "{{jobId}}" },
                                { "key": "workerId", "value": "{{workerId}}" }
                            ]
                        }
                    }
                }
			]
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "Get Unread Notifications",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
						"url": {
							"raw": "{{baseUrl}}/api/notifications",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "notifications" ]
						}
					}
				}
			]
		},
        {
            "name": "Verification",
            "description": "APIs for the worker verification system.",
            "item": [
                {
                    "name": "Worker - Get My Verification Status",
                    "request": {
                        "method": "GET",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
                        "url": {
                            "raw": "{{baseUrl}}/api/verification/status",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "verification", "status"]
                        }
                    }
                },
                {
                    "name": "Worker - Upload Document",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {"key": "type", "value": "AADHAAR", "type": "text"},
                                {"key": "file", "type": "file", "src": []}
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/verification/upload",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "verification", "upload"]
                        }
                    }
                },
                {
                    "name": "Employer - Update Verification Status",
                    "request": {
                        "method": "PUT",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
                        "body": {
                            "mode": "raw",
                            "raw": "\"Verification successful.\"",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/verification/{{verificationId}}/status?status=VERIFIED",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "verification", "{{verificationId}}", "status"],
                            "query": [{"key": "status", "value": "VERIFIED"}]
                        }
                    },
                    "description": "Note: Use an EMPLOYER's token for this request."
                }
            ]
        }
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "token", "value": "" },
		{ "key": "applicationId", "value": "" },
		{ "key": "notificationId", "value": "" },
		{ "key": "jobId", "value": "" },
		{ "key": "workerId", "value": "" },
        { "key": "verificationId", "value": "" }
	]
}
